{
  "name": "@reoclo/cli",
  "version": "0.0.1",
  "description": "Reoclo command-line interface",
  "license": "MIT",
  "bin": { "reoclo": "./dist/reoclo" },
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun run scripts/build-all.ts",
    "test": "bun test",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0"
  }
}
